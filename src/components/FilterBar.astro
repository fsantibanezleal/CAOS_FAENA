---
import { FACETS } from '../lib/catalog';
import { useT, facetLabel, type Lang } from '../i18n/ui';
const { lang } = Astro.props;
const l = lang as Lang;
const t = useT(l);
---
<div class="toolbar">
  <div class="wrap">
    <div class="toolbar-row">
      <input id="search" class="search" type="search" placeholder={t('search.placeholder')} autocomplete="off" />
      <div class="view-toggle" role="group" aria-label="view">
        <button data-view="lanes" aria-pressed="true">{t('view.lanes')}</button>
        <button data-view="matrix" aria-pressed="false">{t('view.matrix')}</button>
      </div>
    </div>
    <div class="toolbar-row" style="margin-top:10px">
      <div class="chips">
        <span class="label">{t('filter.solution')}</span>
        {FACETS.map((f) => (
          <button class="chip" data-facet-chip={f.id} aria-pressed="false" style={`--c:${f.color}`} title={facetLabel(f, l)}>
            <span class="dot"></span>{facetLabel(f, l)}
          </button>
        ))}
      </div>
      <div class="chips">
        <span class="label">{t('filter.status')}</span>
        <button class="chip status-live" data-status-chip="live" aria-pressed="false"><span class="dot"></span>{t('status.live')}</button>
        <button class="chip status-building" data-status-chip="building" aria-pressed="false"><span class="dot"></span>{t('status.building')}</button>
        <button class="chip status-planned" data-status-chip="planned" aria-pressed="false"><span class="dot"></span>{t('status.planned')}</button>
      </div>
      <button class="btn-clear" data-clear hidden>{t('filter.clear')}</button>
    </div>
  </div>
</div>
