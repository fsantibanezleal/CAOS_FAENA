---
import Icon from './Icon.astro';
import { facetById } from '../lib/catalog';
import { useT, type Lang } from '../i18n/ui';
const { app, lang } = Astro.props;
const l = lang as Lang;
const t = useT(l);
const facet = facetById[app.solutionType];
const color = facet?.color ?? 'var(--accent)';
const text = `${app.name} ${app.oneliner}`.toLowerCase();
const isLive = app.status === 'live' && app.links.app;
const adrShort = (app.adr ?? '').replace('ADR-00', 'ADR-');
const ctaLabel = app.status === 'building' ? t('tile.building') : app.status === 'planned' ? t('tile.planned') : t('tile.open');
---
<article class="tile" data-tile data-facet={app.solutionType} data-status={app.status} data-stage={app.stage} data-text={text} style={`--c:${color}`}>
  <div class="tile-top">
    <Icon id={app.solutionType} />
    <span class="name">{app.name}</span>
    <span class={`status-dot ${app.status}`}></span>
  </div>
  <p class="oneliner">{app.oneliner}</p>
  <div class="tile-meta">
    <span class="badge" title={app.dataVerdict.note || ''}><span class={`g ${app.dataVerdict.grade}`}></span>data</span>
    {adrShort && <span class="badge adr">{adrShort}</span>}
  </div>
  <div class="tile-actions">
    {isLive ? (
      <a class="open" href={app.links.app}>{t('tile.open')}</a>
    ) : (
      <span class="open" aria-disabled="true">{ctaLabel}</span>
    )}
    {app.status !== 'planned' && app.links.repo && (
      <a class="repo" href={app.links.repo} target="_blank" rel="noopener">{t('tile.repo')} ↗</a>
    )}
  </div>
</article>
