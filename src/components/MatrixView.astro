---
import Icon from './Icon.astro';
import { STAGES, FACETS, matrixCounts } from '../lib/catalog';
import { useT, stageLabel, facetLabel, type Lang } from '../i18n/ui';
const { lang } = Astro.props;
const l = lang as Lang;
const t = useT(l);
const m = matrixCounts();
const rows = STAGES.filter((s) => FACETS.some((f) => m[s.id][f.id] > 0));
---
<div class="matrix-view" hidden>
  <div class="wrap">
    <p class="matrix-hint">{t('matrix.hint')}</p>
    <div class="matrix-scroll">
      <table class="matrix">
        <thead>
          <tr>
            <th class="row-h"></th>
            {FACETS.map((f) => (
              <th class="facet-th" title={facetLabel(f, l)} style={`color:${f.color}`}><Icon id={f.id} size={16} /></th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((s, i) => (
            <tr>
              <th class="row-h">{i + 1} · {stageLabel(s, l)}</th>
              {FACETS.map((f) => {
                const n = m[s.id][f.id];
                return n > 0 ? (
                  <td class="has" data-mx-stage={s.id} data-mx-facet={f.id} style={`color:${f.color}`}>{n}</td>
                ) : (
                  <td class="zero">·</td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</div>
