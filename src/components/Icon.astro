---
import { facetIcons } from '../lib/icons';
const { id, size = 18 } = Astro.props;
const path = facetIcons[id] ?? '';
---
<svg
  class="ic"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.7"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={path}
></svg>
