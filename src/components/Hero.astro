---
import { stats } from '../lib/catalog';
import { useT, type Lang } from '../i18n/ui';
const { lang } = Astro.props;
const t = useT(lang as Lang);
---
<section class="hero">
  <div class="wrap">
    <h1>Faena</h1>
    <p class="tagline">{t('site.tagline')}</p>
    <p class="intro">{t('site.intro')}</p>
    <div class="stats">
      <span><b>{stats.total}</b> {t('count.apps')}</span>
      <span><b>{stats.live}</b> · {t('status.live')}</span>
      <span><b>{stats.building}</b> · {t('status.building')}</span>
      <span><b>{stats.planned}</b> · {t('status.planned')}</span>
    </div>
  </div>
</section>
