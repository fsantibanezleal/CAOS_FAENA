---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import FilterBar from '../components/FilterBar.astro';
import Lane from '../components/Lane.astro';
import MatrixView from '../components/MatrixView.astro';
import Tile from '../components/Tile.astro';
import { lanes, featured } from '../lib/catalog';
import { useT } from '../i18n/ui';
const lang = 'en';
const t = useT(lang);
const ls = lanes();
const feat = featured();
---
<Base lang={lang} altHref="/es/">
  <Hero lang={lang} />
  <FilterBar lang={lang} />
  <div class="wrap" id="catalog">
    <div class="lanes-view">
      {feat.length > 0 && (
        <>
          <div class="section-title" data-featured-title>★ {t('featured.title')}</div>
          <div class="featured-grid" data-featured>{feat.map((a) => <Tile app={a} lang={lang} />)}</div>
        </>
      )}
      {ls.map((lane, i) => (
        <Lane stage={lane.stage} apps={lane.apps} index={i + 1} lang={lang} collapsed={i >= 7} />
      ))}
      <p class="empty-msg" data-empty>No apps match your filters.</p>
    </div>
    <MatrixView lang={lang} />
  </div>
</Base>
