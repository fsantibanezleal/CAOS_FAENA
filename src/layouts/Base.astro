---
import '../styles/global.css';
import { useT, type Lang } from '../i18n/ui';
const { lang = 'en', altHref = '/es/' } = Astro.props;
const l = lang as Lang;
const t = useT(l);
---
<!doctype html>
<html lang={l} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Faena — Mining Analytics Hub</title>
    <meta name="description" content={t('site.intro')} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://faena.fasl-work.com/" />
    <meta property="og:title" content="Faena — Mining Analytics Hub" />
    <meta property="og:description" content={t('site.tagline')} />
    <meta property="og:type" content="website" />
    <script is:inline>
      (function () {
        try {
          var s = localStorage.getItem('faena-theme');
          var d = s ? s : matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          document.documentElement.dataset.theme = d;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href={l === 'es' ? '/es/' : '/'}>
          <span class="mark">⛰ Faena</span>
          <span class="sub">Mining Analytics</span>
        </a>
        <span class="header-spacer"></span>
        <nav class="header-links">
          <a class="hide-sm" href="https://github.com/fsantibanezleal" target="_blank" rel="noopener">{t('nav.github')} ↗</a>
          <a class="hide-sm" href="https://fasl-work.com" target="_blank" rel="noopener">{t('nav.portfolio')} ↗</a>
          <a href={altHref}>{l === 'es' ? 'EN' : 'ES'}</a>
          <button id="theme-toggle" class="ctrl-btn" type="button" aria-label="Toggle light/dark theme">◐</button>
        </nav>
      </div>
    </header>
    <main><slot /></main>
    <footer class="site-footer">
      <div class="wrap row">
        <span>{t('footer.note')}</span>
        <span class="header-spacer"></span>
        <a href="https://github.com/fsantibanezleal/CAOS_FAENA" target="_blank" rel="noopener">CAOS_FAENA ↗</a>
        <span>© Felipe Santibáñez-Leal</span>
      </div>
    </footer>
    <script>
      import '../scripts/hub.ts';
    </script>
  </body>
</html>
